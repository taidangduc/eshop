{
  "AppOptions": {
    "Name": "API Service",
    "UiUrl": "http://localhost:80"
  },
  "BaseURL": "http://localhost:6005",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "HealthOptions": {
    "Enabled": false
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=EShopDb;Username=postgres;Password=postgres",
    "EShopDb": "Host=postgres;Port=5432;Database=EShopDb;Username=postgres;Password=postgres",
    "rabbitmq": "amqp://guest:guest@rabbitmq:5672"
  },
  "CORS": {
    "AllowAnyOrigin": false,
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://127.0.0.1:3000",
      "http://127.0.0.1:5173",
      "http://host.docker.internal:3000",
      "http://host.docker.internal:5173"
    ]
  },
  "Identity": {
    "Key": "a-string-secret-at-least-256-bits-long",
    "Authority": "https://localhost:6005",
    "Audience": "eshop",
    "ExpiredTime": 15
  },
  "Storage": {
    "Provider": "Azure",
    "Azure": {
      "ConnectionString": "UseDevelopmentStorage=true",
      "Container": "media",
      "Path": "uploads"
    }
  },
  "Payment": {
    "Stripe": {
      "SecretKey": "",
      "WebhookSecret": "",
      "ReturnUrl": "http://localhost:80/checkout/result",
      "Currency": "vnd"
    }
  },
  "Notification":{
    "Email":{
      "SmtpClient":{
        "Host":"xxx",
        "Port": 587,
        "UserName":"",
        "Password":"",
        "EnableSsl": true
      }
    }
  },
  "RabbitMQ": {
    "HostName": "rabbitmq",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "ExchangeName": "eshop_exchange",
    "ExchangeType": "direct",
    "RoutingKeys": {
      "OrderCreatedEvent": "order.created",
      "OrderConfirmedEvent": "order.confirmed",
      "OrderCompletedEvent": "order.completed",
      "OrderCancelledEvent": "order.cancelled",
      "PaymentSucceedEvent": "payment.succeed",
      "PaymentFailedEvent": "payment.failed",
      "StockDecreasedEvent": "stock.decreased",
      "StockDecreaseFailedEvent": "stock.decrease-failed",
      "GracePeriodEvent": "order.grace-period",
      "UserCreatedEvent": "user.created"
    },
    "Consumers": {
      "BasketConsumer": {
        "OrderCreatedEvent": "basket_queue"
      },
      "CustomerConsumer": {
        "UserCreatedEvent": "customer_queue"
      },
      "VariantConsumer": {
        "OrderConfirmedEvent": "variant_queue"
      },
      "OrderConsumer": {
        "StockDecreasedEvent": "order_queue",
        "StockDecreaseFailedEvent": "order_queue",
        "PaymentSucceedEvent": "order_queue",
        "PaymentFailedEvent": "order_queue",
        "GracePeriodEvent": "order_queue"
      }
    }
  },
  "BackgroundTaskOptions": {
    "GracePeriodTime": "1",
    "CheckUpdateTime": "30"
  }
}
