{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.DataProtection": "Debug"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=EShopDb;Username=postgres;Password=postgres",
    "EShopDb": "Host=localhost;Port=5432;Database=EShopDb;Username=postgres;Password=postgres",
    "rabbitmq": "amqp://guest:guest@localhost:5672"
  },
  "CORS": {
    "AllowAnyOrigin": false,
    "AllowedOrigins": ["https://localhost:5002","http://localhost:3000","http://localhost:5173"]
  }, 
  "Identity": {
    "Key": "a-string-secret-at-least-256-bits-long",
    "Authority": "https://localhost:6005",
    "Audience": "eshop",
    "ExpiredTime": 15
  },
  "Storage": {
    "Provider": "Azure",
    "Azure": {
      "ConnectionString": "UseDevelopmentStorage=true",
      "Container": "media",
      "Path": "uploads"
    },
    "Local": {
      "Path": "C:\\Data\\files"
    }
  },
  "Payment": {
    "Stripe": {
      "SecretKey": "",
      "WebhookSecret": "",
      "ReturnUrl": "http://localhost:3000/checkout/status",
      "Currency": "vnd"
    }
  },
  "Notification":{
    "Email":{
      "SmtpClient":{
        "Host":"xxx",
        "Port": 587,
        "UserName":"",
        "Password":"",
        "EnableSsl": true
      }
    }
  }
}

